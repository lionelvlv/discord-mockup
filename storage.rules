rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Only authenticated users may read or write anything
    function isSignedIn() {
      return request.auth != null;
    }

    // File must be uploaded to the uploading user's own folder
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Hard size cap: 25 MB
    function withinSizeLimit() {
      return request.resource.size <= 25 * 1024 * 1024;
    }

    // Strict MIME type allowlist — mirrors the client-side check in mediaUpload.ts.
    // Storage rules are the server-side gate; the client check is UX only.
    function isAllowedType() {
      return request.resource.contentType.matches('image/(jpeg|jpg|png|gif|webp|avif)')
          || request.resource.contentType.matches('video/(mp4|webm|ogg|quicktime)')
          || request.resource.contentType.matches('audio/(mpeg|mp3|ogg|wav|webm|aac|flac)')
          || request.resource.contentType == 'application/pdf';
    }

    // User uploads live at uploads/{userId}/{filename}
    match /uploads/{userId}/{filename} {
      // Anyone signed in can read (needed to display images/video in chat)
      allow read: if isSignedIn();

      // Only the owning user can write, and only allowed types within size limit
      allow write: if isSignedIn()
                   && isOwner(userId)
                   && withinSizeLimit()
                   && isAllowedType();

      // Users can delete their own uploads (e.g. message deleted)
      allow delete: if isSignedIn() && isOwner(userId);
    }

    // Block everything else — no other paths are accessible
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
